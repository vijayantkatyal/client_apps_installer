{
  "base_url": "https://license.lpal.net",
  "endpoints": {
    "validate_license": "/api/license/validate",
    "get_download_token": "/api/download/token",
    "get_download_url": "/api/download/url",
    "list_versions": "/api/versions",
    "check_updates": "/api/updates/check",
    "get_update_url": "/api/updates/download",
    "get_products_info": "/api/license/all/products"
  },
  "security": {
    "token_expiry": 3600,
    "max_download_size": "500MB",
    "allowed_protocols": ["http", "https"],
    "verify_ssl": false
  },
  "fallback": {
    "timeout": 30,
    "retry_attempts": 3,
    "retry_delay": 5
  }
}
