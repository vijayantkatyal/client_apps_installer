{
  "vidpowr": {
    "name": "VidPowr Video Platform",
    "description": "Professional video hosting and streaming platform",
    "version": "2.1.0",
    "license_server": "https://api.vidpowr.com",
    "release_server": "https://releases.vidpowr.com",
    "icon": "🎬",
    "category": "video",
    "requirements": {
      "php": "^8.0",
      "extensions": ["mysqli", "pdo", "pdo_mysql", "gd", "zip", "bcmath", "curl", "json", "mbstring", "openssl", "tokenizer", "xml"],
      "database": "mysql",
      "memory_limit": "256M",
      "disk_space": "2GB"
    },
    "post_install": {
      "migrations": true,
      "seeders": ["AdminSeeder", "SettingsSeeder", "VideoSeeder"],
      "commands": ["key:generate", "storage:link", "config:cache", "route:cache"],
      "permissions": [
        "storage",
        "bootstrap/cache"
      ]
    },
    "features": {
      "normal": ["video_upload", "basic_analytics", "embed_player"],
      "agency": ["video_upload", "advanced_analytics", "embed_player", "api_access", "white_label", "multi_domain"]
    }
  },
  "blogpro": {
    "name": "BlogPro CMS",
    "description": "Professional content management system for bloggers",
    "version": "1.5.2",
    "license_server": "https://api.blogpro.com",
    "release_server": "https://releases.blogpro.com",
    "icon": "📝",
    "category": "cms",
    "requirements": {
      "php": "^8.0",
      "extensions": ["mysqli", "pdo", "pdo_mysql", "gd", "zip", "curl", "json", "mbstring", "openssl"],
      "database": "mysql",
      "memory_limit": "128M",
      "disk_space": "500MB"
    },
    "post_install": {
      "migrations": true,
      "seeders": ["AdminSeeder", "ThemeSeeder", "WidgetSeeder"],
      "commands": ["key:generate", "storage:link"],
      "permissions": [
        "storage",
        "bootstrap/cache"
      ]
    },
    "features": {
      "normal": ["blog_posts", "categories", "comments", "themes"],
      "agency": ["blog_posts", "categories", "comments", "themes", "multi_user", "api_access", "advanced_seo"]
    }
  },
  "shoplite": {
    "name": "ShopLite E-commerce",
    "description": "Lightweight e-commerce platform for online stores",
    "version": "3.0.1",
    "license_server": "https://api.shoplite.com",
    "release_server": "https://releases.shoplite.com",
    "icon": "🛒",
    "category": "ecommerce",
    "requirements": {
      "php": "^8.1",
      "extensions": ["mysqli", "pdo", "pdo_mysql", "gd", "zip", "bcmath", "curl", "json", "mbstring", "openssl", "tokenizer"],
      "database": "mysql",
      "memory_limit": "512M",
      "disk_space": "1GB"
    },
    "post_install": {
      "migrations": true,
      "seeders": ["AdminSeeder", "ProductSeeder", "PaymentSeeder"],
      "commands": ["key:generate", "storage:link", "config:cache"],
      "permissions": [
        "storage",
        "bootstrap/cache"
      ]
    },
    "features": {
      "normal": ["products", "orders", "payments", "inventory"],
      "agency": ["products", "orders", "payments", "inventory", "multi_store", "api_access", "advanced_reports"]
    }
  }
}
