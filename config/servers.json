{
  "license_servers": {
    "vidpowr": "http://localhost:9000",
    "blogpro": "http://localhost:9000", 
    "shoplite": "http://localhost:9000"
  },
  "release_servers": {
    "vidpowr": "http://localhost:9001",
    "blogpro": "http://localhost:9001",
    "shoplite": "http://localhost:9001"
  },
  "endpoints": {
    "validate_license": "/api/validate",
    "get_download_token": "/api/download/token",
    "get_download_url": "/api/download/url",
    "list_versions": "/api/versions",
    "check_updates": "/api/updates/check",
